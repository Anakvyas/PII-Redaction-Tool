# Copy to .env for local overrides. Every value here has a working default,
# so the app runs with zero configuration for local development.

APP_NAME=PII Redaction API
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=false

# Empty disables auth (local dev only) — set a real value in production.
API_KEY=
SECRET_KEY=dev-only-insecure-secret-change-me
CORS_ORIGINS=["http://localhost:3000"]

# Leave unset to use the built-in SQLite file under backend/storage/. Point
# this at Postgres in production — do not uncomment with an empty value, an
# empty string overrides the SQLite default instead of falling back to it.
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/pii_redactor

# local | s3
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=./storage/files
SIGNED_URL_TTL_SECONDS=900

S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

MAX_UPLOAD_SIZE_BYTES=26214400
DEFAULT_CONFIDENCE_FLOOR=0.75
SPACY_MODEL=en_core_web_lg
